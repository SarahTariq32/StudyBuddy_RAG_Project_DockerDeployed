LLM_PROVIDER=groq

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free

# For production, set this to your frontend origin.
# Example: CORS_ORIGINS=https://your-frontend.vercel.app
# Multiple origins (comma-separated): CORS_ORIGINS=https://app.example.com,https://staging.example.com
CORS_ORIGINS=*

# Maximum PDF file size in megabytes (default: 50).
MAX_FILE_SIZE_MB=50

# --- Storage paths ---
# In production on Railway/Render, point these at a mounted persistent volume
# so data survives redeployments. Example (Railway persistent volume at /data):
#   PDF_STORAGE_PATH=/data/pdfs
#   CHROMA_PATH=/data/chroma_db
#   DB_PATH=/data/app.db
# Leave blank to use the default paths inside the container (ephemeral — data
# is wiped on every redeploy if no persistent volume is attached).
PDF_STORAGE_PATH=
CHROMA_PATH=
DB_PATH=

# Optional tuning (defaults shown)
# EMBEDDING_BATCH_SIZE=48
# PARENT_CHUNK_SIZE=1500
# CHILD_CHUNK_SIZE=500
# CHUNK_OVERLAP=50
# MAX_CHILD_CHUNKS=450
# MAX_PDF_PAGES=40
# DISTANCE_THRESHOLD=1.2
