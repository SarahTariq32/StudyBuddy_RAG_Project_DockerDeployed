# Docker Compose Environment Variables
# Copy this to .env and fill in your actual API keys

# LLM Provider Selection (gemini, groq, or openrouter)
LLM_PROVIDER=groq

# Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Groq Configuration
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter Configuration
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free

# LangSmith Observability (optional)
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=studybuddy-rag

# File Upload Limits
MAX_FILE_SIZE_MB=50

# Embedding & Chunking Tuning (optional - defaults shown)
EMBEDDING_BATCH_SIZE=48
PARENT_CHUNK_SIZE=1500
CHILD_CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_CHILD_CHUNKS=450
MAX_PDF_PAGES=40

# Retrieval Tuning (optional)
NUM_MULTI_QUERIES=2
DISTANCE_THRESHOLD=1.2
